---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Layout from './Layout.astro';

type ReferenceModule = {
  name: string;
  href: string;
  description: string;
};

const { frontmatter } = Astro.props;
const modules = (frontmatter.referenceModules ?? []) as ReferenceModule[];
---

<Layout title={`${frontmatter.title} — roost reference`} description={frontmatter.description}>
  <Nav />
  <main id="main" class="reference-shell container">
    <aside class="reference-sidebar" aria-label="Reference modules">
      <a class="reference-back" href="/reference/">Reference</a>
      <nav>
        {modules.map((module) => (
          <a href={module.href} title={module.description}>{module.name}</a>
        ))}
      </nav>
    </aside>
    <article class="reference-content">
      <slot />
    </article>
  </main>
  <Footer />
</Layout>

<style is:global>
  .reference-shell {
    display: grid;
    grid-template-columns: minmax(12rem, 16rem) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    padding-block: clamp(2.5rem, 7vw, 5rem);
  }

  .reference-sidebar {
    position: sticky;
    top: 6rem;
    align-self: start;
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--r-lg);
    background: color-mix(in oklch, var(--surface), transparent 30%);
  }

  .reference-sidebar nav {
    display: grid;
    gap: 0.35rem;
  }

  .reference-sidebar a {
    color: var(--muted);
  }

  .reference-sidebar a:hover,
  .reference-sidebar .reference-back {
    color: var(--ink);
  }

  .reference-back {
    font-family: var(--font-display);
    font-weight: 700;
  }

  .reference-content {
    min-width: 0;
    max-width: var(--container-narrow);
  }

  .reference-content > * + * {
    margin-top: 1.1rem;
  }

  .reference-content h1 {
    margin-bottom: 1.25rem;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
  }

  .reference-content h2 {
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border-soft);
    font-size: clamp(1.7rem, 4vw, 2.5rem);
  }

  .reference-content h3 {
    margin-top: 2rem;
    font-size: clamp(1.25rem, 3vw, 1.65rem);
  }

  .reference-content h4,
  .reference-content h5 {
    margin-top: 1.5rem;
  }

  .reference-content a {
    color: var(--brand-bright);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .reference-content :not(pre) > code {
    padding: 0.12em 0.34em;
    border: 1px solid var(--border-soft);
    border-radius: 0.35rem;
    background: var(--surface);
    color: var(--ink);
    font-size: 0.9em;
  }

  .reference-content pre {
    overflow-x: auto;
    padding: 1.1rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    color: var(--ink);
    line-height: 1.55;
  }

  .reference-content table {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
    border: 1px solid var(--border-soft);
    border-radius: var(--r-md);
  }

  .reference-content th,
  .reference-content td {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border-soft);
    text-align: left;
    vertical-align: top;
  }

  .reference-content tr:last-child td {
    border-bottom: 0;
  }

  .reference-note,
  .reference-caution {
    padding: 1rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--r-md);
    background: var(--surface);
  }

  .reference-caution {
    border-color: color-mix(in oklch, var(--brand), var(--border) 55%);
    background: var(--brand-tint);
  }

  @media (max-width: 820px) {
    .reference-shell {
      grid-template-columns: 1fr;
    }

    .reference-sidebar {
      position: static;
    }
  }
</style>
