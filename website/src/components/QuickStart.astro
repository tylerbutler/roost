---
import CopyCommand from './CopyCommand.astro';

const repo = 'https://github.com/tylerbutler/roost';
const steps = [
  {
    n: '1',
    t: 'Add the package',
    d: 'Pull roost into your Gleam project. No transitive runtime — it depends only on the standard library and gleam_json.',
    cmd: 'gleam add roost',
  },
  {
    n: '2',
    t: 'Import & encode',
    d: 'Build a frame with labelled arguments and hand the string to whatever socket you already use.',
    code: 'import roost\n\nroost.encode(\n  join_ref: Some("1"),\n  ref: Some("1"),\n  topic: "room:lobby",\n  event: "phx_join",\n  payload: payload,\n)',
  },
  {
    n: '3',
    t: 'Decode what comes back',
    d: 'Turn inbound socket text into a typed Incoming value, and handle InvalidJson / InvalidFormat as ordinary results.',
    code: 'case roost.decode(text) {\n  Ok(incoming) -> handle(incoming)\n  Error(err) -> log(err)\n}',
  },
];
---

<section class="start" id="start" aria-labelledby="start-title">
  <div class="container">
    <div class="start-head">
      <p class="eyebrow"><span class="eyebrow-tick">//</span> three steps, no ceremony</p>
      <h2 id="start-title">Settle in.</h2>
    </div>

    <ol class="steps">
      {steps.map((s) => (
        <li class="step">
          <span class="step-n" aria-hidden="true">{s.n}</span>
          <div class="step-body">
            <h3 class="step-t">{s.t}</h3>
            <p class="step-d">{s.d}</p>
            {s.cmd && <CopyCommand command={s.cmd} />}
            {s.code && <pre class="step-code"><code>{s.code}</code></pre>}
          </div>
        </li>
      ))}
    </ol>

    <div class="start-cta">
      <p>Pre-0.1 and honest about it — the API can still move. Watch the repo to track it.</p>
      <a class="cta-btn" href={repo} target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.6-4.04-1.6-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.92 1.23 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/>
        </svg>
        Read the source on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .start {
    padding-block: var(--space-section);
  }

  .start-head {
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .start-head .eyebrow { margin-bottom: 1rem; }
  .eyebrow-tick { color: var(--brand); }

  .start-head h2 {
    font-size: clamp(2rem, 1.5rem + 2.5vw, 3.25rem);
  }

  .steps {
    list-style: none;
    margin: 0 0 clamp(3rem, 6vw, 4.5rem);
    padding: 0;
    display: grid;
    gap: 0;
  }

  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    padding-block: clamp(1.75rem, 3vw, 2.5rem);
    border-top: 1px solid var(--border-soft);
  }
  .step:last-child {
    border-bottom: 1px solid var(--border-soft);
  }

  .step-n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 2vw, 3rem);
    font-weight: 700;
    line-height: 1;
    color: var(--brand);
    width: clamp(2.5rem, 5vw, 3.5rem);
    text-align: right;
  }

  .step-t {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }

  .step-d {
    color: var(--muted);
    max-width: 54ch;
    margin-bottom: 1.25rem;
  }

  .step-code {
    margin: 0;
    padding: 1.1rem 1.3rem;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--ink);
    max-width: 38rem;
  }
  .step-code code {
    font-family: var(--font-mono);
    color: inherit;
  }

  .start-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    background:
      linear-gradient(120deg, var(--brand-tint), transparent 60%),
      var(--surface);
    border: 1px solid color-mix(in oklch, var(--brand) 25%, var(--border));
    border-radius: var(--r-lg);
  }

  .start-cta p {
    color: var(--ink-2);
    max-width: 42ch;
    margin: 0;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1.4rem;
    background: var(--brand);
    color: var(--on-brand);
    font-weight: 700;
    border-radius: var(--r-pill);
    white-space: nowrap;
    transition: background 0.2s var(--ease-out-quint), transform 0.2s var(--ease-out-quint);
  }

  .cta-btn:hover {
    background: var(--brand-bright);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-btn:hover {
      transform: none;
    }
  }
</style>
