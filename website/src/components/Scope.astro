---
const does = [
  {
    t: 'Encode outbound frames',
    d: 'Build the Phoenix wire array <code>[join_ref, ref, topic, event, payload]</code> from typed Gleam values.',
  },
  {
    t: 'Decode inbound frames',
    d: 'Parse raw socket text back into a typed <code>Incoming</code> value, with explicit <code>DecodeError</code>s.',
  },
  {
    t: 'Reserved-event constants',
    d: '<code>phx_join</code>, <code>phx_leave</code>, <code>phx_reply</code>, <code>phx_error</code>, <code>phx_close</code>, <code>heartbeat</code>.',
  },
  {
    t: 'Heartbeat & reply helpers',
    d: 'Construct heartbeat frames on the <code>"phoenix"</code> topic and well-formed reply frames.',
  },
  {
    t: 'Reply statuses & error types',
    d: 'Typed reply statuses and decode errors instead of stringly-typed guesswork.',
  },
];

const youBring = [
  { t: 'Opening & closing sockets', d: 'roost never touches a WebSocket. Use Mist or any Erlang transport.' },
  { t: 'Channel processes & lifecycle', d: 'Join / leave state machines and supervision live in your runtime.' },
  { t: 'Ref counters & join refs', d: 'Refs are plain strings on the wire; the monotonic counter is yours.' },
  { t: 'Reconnects, rejoins & timeouts', d: 'Backoff, retry, and rejoin policy are application decisions.' },
  { t: 'Heartbeat scheduling & Presence', d: 'roost builds the frame; when to send it is up to you.' },
];
---

<section class="scope" id="scope" aria-labelledby="scope-title">
  <div class="container">
    <div class="scope-head">
      <p class="eyebrow"><span class="eyebrow-tick">//</span> the boundary is the feature</p>
      <h2 id="scope-title">
        roost does one thing.<br />It does it <span class="hl">completely</span>.
      </h2>
      <p class="scope-sub">
        Most of evaluating a small library is finding out where it stops. So
        here's the line, drawn on purpose — what roost owns, and what stays
        yours.
      </p>
    </div>

    <div class="ledger">
      <div class="col col-does">
        <div class="col-head">
          <span class="col-tag tag-does">roost handles</span>
          <span class="col-count">{does.length} things</span>
        </div>
        <ul class="rows">
          {does.map((item) => (
            <li class="row">
              <span class="glyph glyph-does" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
              </span>
              <span class="row-text">
                <span class="row-t" set:html={item.t} />
                <span class="row-d" set:html={item.d} />
              </span>
            </li>
          ))}
        </ul>
      </div>

      <div class="seam" aria-hidden="true">
        <span class="seam-line"></span>
        <span class="seam-label">your code ⟶</span>
        <span class="seam-line"></span>
      </div>

      <div class="col col-you">
        <div class="col-head">
          <span class="col-tag tag-you">you bring</span>
          <span class="col-count">your runtime</span>
        </div>
        <ul class="rows">
          {youBring.map((item) => (
            <li class="row">
              <span class="glyph glyph-you" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                  <path d="M5 12h14" />
                </svg>
              </span>
              <span class="row-text">
                <span class="row-t" set:html={item.t} />
                <span class="row-d" set:html={item.d} />
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .scope {
    padding-block: var(--space-section);
  }

  .scope-head {
    max-width: 40rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .eyebrow { margin-bottom: 1rem; }
  .eyebrow-tick { color: var(--brand); }

  .scope-head h2 {
    font-size: clamp(2rem, 1.4rem + 3vw, 3.25rem);
    margin-bottom: 1.25rem;
  }
  .scope-head .hl { color: var(--brand); }

  .scope-sub {
    color: var(--muted);
    max-width: 52ch;
    font-size: 1.075rem;
  }

  .ledger {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: clamp(1.25rem, 3vw, 2.75rem);
    align-items: stretch;
  }

  .col {
    border-radius: var(--r-lg);
    padding: clamp(1.25rem, 2.5vw, 2rem);
  }

  .col-does {
    background:
      linear-gradient(180deg, var(--brand-tint), transparent 70%),
      var(--surface);
    border: 1px solid color-mix(in oklch, var(--brand) 28%, var(--border));
  }

  .col-you {
    background: color-mix(in oklch, var(--bg-deep) 60%, transparent);
    border: 1px dashed var(--border);
  }

  .col-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .col-tag {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .tag-does { color: var(--brand-bright); }
  .tag-you { color: var(--ink-2); }

  .col-count {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--faint);
  }

  .rows {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  .row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: start;
  }

  .glyph {
    margin-top: 0.15rem;
    width: 1.45rem;
    height: 1.45rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .glyph-does {
    color: var(--on-brand);
    background: var(--brand);
  }
  .glyph-you {
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--border-strong);
  }

  .row-text { display: block; }

  .row-t {
    display: block;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.15rem;
  }

  .row-d {
    display: block;
    font-size: 0.925rem;
    color: var(--muted);
    line-height: 1.55;
  }

  .row-d :global(code),
  .row-t :global(code) {
    font-size: 0.85em;
    color: var(--brand-bright);
    background: color-mix(in oklch, var(--brand) 12%, transparent);
    padding: 0.05em 0.35em;
    border-radius: 5px;
    white-space: nowrap;
  }
  .col-you .row-d :global(code) {
    color: var(--ink-2);
    background: var(--surface-2);
  }

  /* ---- Seam ---- */
  .seam {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    padding-block: 0.5rem;
  }

  .seam-line {
    flex: 1;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--border-strong),
      transparent
    );
  }

  .seam-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
    writing-mode: vertical-rl;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .ledger {
      grid-template-columns: 1fr;
    }
    .seam {
      flex-direction: row;
      width: 100%;
    }
    .seam-line {
      width: auto;
      height: 1px;
      flex: 1;
      background: linear-gradient(to right, transparent, var(--border-strong), transparent);
    }
    .seam-label {
      writing-mode: horizontal-tb;
    }
  }
</style>
