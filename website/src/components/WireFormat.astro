---
const frames = [
  {
    id: 'join',
    label: 'phx_join',
    title: 'Join a channel',
    summary: 'A client asks Phoenix to join a topic.',
    cells: [
      { i: 0, name: 'join_ref', value: '"1"', type: 'Option(String)', desc: 'Ties future replies to this specific channel join. It is usually present for join-related traffic.', gleam: 'join_ref: Some("1")' },
      { i: 1, name: 'ref', value: '"1"', type: 'Option(String)', desc: 'Per-message reference used to match the eventual phx_reply back to this request.', gleam: 'ref: Some("1")' },
      { i: 2, name: 'topic', value: '"room:lobby"', type: 'String', desc: 'The channel topic this frame belongs to. roost keeps it as plain protocol data; your runtime owns the socket.', gleam: 'topic: "room:lobby"' },
      { i: 3, name: 'event', value: '"phx_join"', type: 'String', desc: 'The reserved Phoenix event for joining a channel. roost exposes reserved-event helpers so callers do not hand-roll protocol checks.', gleam: 'event: "phx_join"' },
      { i: 4, name: 'payload', value: '{ name }', type: 'Payload(json.Json)', desc: 'Application JSON sent with the join. BinaryPayload selects Phoenix’s binary serializer instead.', gleam: 'payload: frame.JsonPayload(json.object([#("name", json.string("alice"))]))' },
    ],
  },
  {
    id: 'heartbeat',
    label: 'heartbeat',
    title: 'Keep the socket alive',
    summary: 'Phoenix heartbeats use the same five slots.',
    cells: [
      { i: 0, name: 'join_ref', value: 'null', type: 'Option(String)', desc: 'Heartbeats are not tied to a channel join, so this slot is null on the wire.', gleam: 'join_ref: None' },
      { i: 1, name: 'ref', value: '"2"', type: 'Option(String)', desc: 'The caller still owns the ref. roost builds the frame, not the counter.', gleam: 'ref: Some("2")' },
      { i: 2, name: 'topic', value: '"phoenix"', type: 'String', desc: 'Phoenix reserves the literal "phoenix" topic for heartbeat traffic.', gleam: 'topic: "phoenix"' },
      { i: 3, name: 'event', value: '"heartbeat"', type: 'String', desc: 'The reserved event that tells Phoenix this frame is a heartbeat.', gleam: 'event: "heartbeat"' },
      { i: 4, name: 'payload', value: '{}', type: 'Payload(json.Json)', desc: 'Heartbeat payloads are empty JSON by convention; scheduling them is still your runtime\'s job.', gleam: 'payload: frame.JsonPayload(json.object([]))' },
    ],
  },
  {
    id: 'reply',
    label: 'phx_reply',
    title: 'Receive a reply',
    summary: 'Replies point back to the request ref.',
    cells: [
      { i: 0, name: 'join_ref', value: '"1"', type: 'Option(String)', desc: 'Carries the join reference when Phoenix can associate the reply with a channel join.', gleam: 'join_ref: Some("1")' },
      { i: 1, name: 'ref', value: '"1"', type: 'Option(String)', desc: 'Matches the request that Phoenix is answering. This is how callers route replies.', gleam: 'ref: Some("1")' },
      { i: 2, name: 'topic', value: '"room:lobby"', type: 'String', desc: 'The channel topic the reply belongs to.', gleam: 'topic: "room:lobby"' },
      { i: 3, name: 'event', value: '"phx_reply"', type: 'String', desc: 'The reserved event that marks this frame as a Phoenix reply.', gleam: 'event: "phx_reply"' },
      { i: 4, name: 'payload', value: '{ status }', type: 'Reply', desc: 'roost normalises Phoenix text and binary replies into a typed Reply frame with status and response fields.', gleam: 'frame.Reply(ref:, status:, response:, ..)' },
    ],
  },
];

const initialFrame = frames[0];
const initialCell = initialFrame.cells[3];
---

<section class="wire" id="wire" aria-labelledby="wire-title">
  <div class="container">
    <div class="wire-head">
      <p class="wire-kicker">Tiny protocol inspector</p>
      <h2 id="wire-title">Text arrays. Binary headers.</h2>
      <p class="wire-sub">
        Text frames use the familiar five-slot array shown below. Binary frames
        use Phoenix's compact direction-specific kind 0/1/2 headers followed by
        raw payload bytes; roost maps both into the same typed frame model.
      </p>
    </div>

    <div
      class="inspector"
      data-protocol-inspector
      data-active-frame={initialFrame.id}
      data-active-slot={initialCell.i}
    >
      <div class="presets" role="tablist" aria-label="Frame examples">
        {frames.map((frame, index) => (
          <button
            class:list={['preset', index === 0 && 'is-active']}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            data-frame={frame.id}
          >
            <span>{frame.label}</span>
            <small>{frame.summary}</small>
          </button>
        ))}
      </div>

      <div class="inspector-body">
        <div class="frame-area" aria-label="Phoenix channel frame">
          <div class="frame-meta">
            <span class="frame-title" data-frame-title>{initialFrame.title}</span>
            <span class="frame-shape">[join_ref, ref, topic, event, payload]</span>
          </div>

          <div class="frame-line">
            <span class="bracket" aria-hidden="true">[</span>
            <ol class="slots">
              {initialFrame.cells.map((cell) => (
                <li>
                  <button
                    class:list={['slot', cell.i === initialCell.i && 'is-active']}
                    type="button"
                    data-slot={cell.i}
                    aria-pressed={cell.i === initialCell.i ? 'true' : 'false'}
                    style={`--i:${cell.i}`}
                  >
                    <span class="slot-index">{cell.i}</span>
                    <span class="slot-name" data-field="name">{cell.name}</span>
                    <code class="slot-value" data-field="value">{cell.value}</code>
                  </button>
                </li>
              ))}
            </ol>
            <span class="bracket" aria-hidden="true">]</span>
          </div>
        </div>

        <aside class="detail" aria-live="polite" aria-label="Selected slot details">
          <p class="detail-label">Selected slot</p>
          <div class="detail-head">
            <h3 data-detail-name>{initialCell.name}</h3>
            <span data-detail-type>{initialCell.type}</span>
          </div>
          <p class="detail-desc" data-detail-desc>{initialCell.desc}</p>
          <pre class="gleam-map"><code data-detail-gleam>{initialCell.gleam}</code></pre>
        </aside>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ frames }}>
  const inspectors = document.querySelectorAll('[data-protocol-inspector]');

  for (const inspector of inspectors) {
    const presets = Array.from(inspector.querySelectorAll('[data-frame]'));
    const slots = Array.from(inspector.querySelectorAll('[data-slot]'));
    const frameTitle = inspector.querySelector('[data-frame-title]');
    const detailName = inspector.querySelector('[data-detail-name]');
    const detailType = inspector.querySelector('[data-detail-type]');
    const detailDesc = inspector.querySelector('[data-detail-desc]');
    const detailGleam = inspector.querySelector('[data-detail-gleam]');

    const setActive = (frameId, slotIndex) => {
      const frame = frames.find((item) => item.id === frameId) ?? frames[0];
      const cell = frame.cells.find((item) => item.i === slotIndex) ?? frame.cells[0];

      inspector.dataset.activeFrame = frame.id;
      inspector.dataset.activeSlot = String(cell.i);

      if (frameTitle) frameTitle.textContent = frame.title;
      if (detailName) detailName.textContent = cell.name;
      if (detailType) detailType.textContent = cell.type;
      if (detailDesc) detailDesc.textContent = cell.desc;
      if (detailGleam) detailGleam.textContent = cell.gleam;

      presets.forEach((preset) => {
        const isActive = preset.dataset.frame === frame.id;
        preset.classList.toggle('is-active', isActive);
        preset.setAttribute('aria-selected', String(isActive));
      });

      slots.forEach((slot) => {
        const slotNumber = Number(slot.dataset.slot);
        const nextCell = frame.cells.find((item) => item.i === slotNumber);
        const isActive = slotNumber === cell.i;
        slot.classList.toggle('is-active', isActive);
        slot.setAttribute('aria-pressed', String(isActive));
        slot.querySelector('[data-field="name"]').textContent = nextCell.name;
        slot.querySelector('[data-field="value"]').textContent = nextCell.value;
      });
    };

    presets.forEach((preset) => {
      preset.addEventListener('click', () => {
        const activeSlot = Number(inspector.dataset.activeSlot ?? 3);
        setActive(preset.dataset.frame, activeSlot);
      });
    });

    slots.forEach((slot) => {
      slot.addEventListener('click', () => {
        setActive(inspector.dataset.activeFrame, Number(slot.dataset.slot));
      });
    });
  }
</script>

<style>
  .wire {
    padding-block: var(--space-section);
    background:
      radial-gradient(80% 50% at 50% 0%, var(--weave-tint), transparent 70%);
  }

  .wire-head {
    max-width: 44rem;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
  }

  .wire-kicker {
    margin-bottom: 0.9rem;
    color: var(--brand-bright);
    font-weight: 700;
  }

  .wire-head h2 {
    font-size: clamp(2rem, 1.5rem + 2.5vw, 3.25rem);
    margin-bottom: 1.1rem;
  }

  .wire-sub {
    color: var(--muted);
    font-size: 1.075rem;
    margin-inline: auto;
    max-width: 54ch;
  }

  .inspector {
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    background:
      linear-gradient(135deg, color-mix(in oklch, var(--brand-tint), transparent 40%), transparent 42%),
      var(--bg-deep);
    overflow: hidden;
  }

  .presets {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid var(--border-soft);
    background: color-mix(in oklch, var(--surface), transparent 18%);
  }

  .preset {
    display: grid;
    gap: 0.2rem;
    padding: 1rem clamp(0.9rem, 2vw, 1.25rem);
    color: var(--muted);
    text-align: left;
    background: transparent;
    border: 0;
    border-right: 1px solid var(--border-soft);
    cursor: pointer;
    transition:
      color 0.2s var(--ease-out-quint),
      background 0.2s var(--ease-out-quint);
  }

  .preset:last-child {
    border-right: 0;
  }

  .preset span {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--ink-2);
  }

  .preset small {
    font: inherit;
    font-size: 0.84rem;
    line-height: 1.35;
  }

  .preset:hover,
  .preset.is-active {
    color: var(--ink-2);
    background: color-mix(in oklch, var(--brand-tint), transparent 38%);
  }

  .preset.is-active span {
    color: var(--brand-bright);
  }

  .inspector-body {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .frame-area {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2rem);
    align-content: center;
    min-width: 0;
    padding: clamp(0.5rem, 2vw, 1rem);
  }

  .frame-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1rem;
  }

  .frame-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1rem + 1.4vw, 2rem);
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .frame-shape {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--faint);
  }

  .frame-line {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    min-width: 0;
  }

  .bracket {
    align-self: center;
    color: color-mix(in oklch, var(--brand) 60%, var(--border-strong));
    font-family: var(--font-mono);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 300;
    line-height: 1;
  }

  .slots {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    flex: 1;
    gap: clamp(0.45rem, 1vw, 0.75rem);
    min-width: 0;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .slot {
    position: relative;
    display: grid;
    gap: 0.35rem;
    width: 100%;
    min-height: 7.2rem;
    padding: 1rem 0.75rem;
    color: var(--ink-2);
    text-align: left;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    cursor: pointer;
    transition:
      transform 0.25s var(--ease-out-quint),
      border-color 0.25s var(--ease-out-quint),
      background 0.25s var(--ease-out-quint);
  }

  .slot::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -0.85rem;
    width: 0.75rem;
    height: 0.75rem;
    background: var(--brand);
    clip-path: polygon(50% 100%, 0 0, 100% 0);
    opacity: 0;
    transform: translateX(-50%) translateY(-0.25rem);
    transition:
      opacity 0.2s var(--ease-out-quint),
      transform 0.2s var(--ease-out-quint);
  }

  .slot:hover,
  .slot.is-active {
    transform: translateY(-3px);
    border-color: color-mix(in oklch, var(--brand) 55%, var(--border));
    background: color-mix(in oklch, var(--brand-tint), var(--surface));
  }

  .slot.is-active::after {
    opacity: 1;
    transform: translateX(-50%);
  }

  .slot-index {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
  }

  .slot-name {
    font-family: var(--font-mono);
    font-size: clamp(0.78rem, 0.7rem + 0.35vw, 0.95rem);
    font-weight: 700;
    color: var(--brand-bright);
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }

  .slot-value {
    max-width: 100%;
    overflow: hidden;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .detail {
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: clamp(1.1rem, 2vw, 1.35rem);
    background: color-mix(in oklch, var(--surface), transparent 12%);
    border: 1px solid var(--border-soft);
    border-radius: var(--r-md);
  }

  .detail-label {
    color: var(--brand-bright);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .detail-head {
    display: grid;
    gap: 0.35rem;
  }

  .detail h3 {
    font-size: clamp(1.55rem, 1.2rem + 1.6vw, 2.2rem);
  }

  .detail-head span {
    width: fit-content;
    padding: 0.2rem 0.55rem;
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: var(--surface-2);
    border-radius: var(--r-pill);
  }

  .detail-desc {
    color: var(--ink-2);
    line-height: 1.6;
  }

  .gleam-map {
    margin: 0;
    padding: 0.85rem 1rem;
    overflow-x: auto;
    color: var(--ink);
    background: var(--bg-deep);
    border: 1px solid var(--border-soft);
    border-radius: var(--r-sm);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .gleam-map code {
    font-family: var(--font-mono);
  }

  @media (max-width: 900px) {
    .inspector-body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .presets {
      grid-template-columns: 1fr;
    }

    .preset {
      border-right: 0;
      border-bottom: 1px solid var(--border-soft);
    }

    .preset:last-child {
      border-bottom: 0;
    }

    .frame-line {
      display: block;
    }

    .bracket {
      display: none;
    }

    .slots {
      grid-template-columns: 1fr;
    }

    .slot {
      grid-template-columns: auto minmax(8rem, 1fr) auto;
      align-items: baseline;
      min-height: 0;
      gap: 0.6rem;
      padding: 0.9rem 1rem;
    }

    .slot::after {
      left: auto;
      right: 1rem;
      bottom: -0.45rem;
    }

    .slot-value {
      justify-self: end;
      white-space: normal;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .preset,
    .slot,
    .slot::after {
      transition: none;
    }

    .slot:hover,
    .slot.is-active {
      transform: none;
    }
  }
</style>
