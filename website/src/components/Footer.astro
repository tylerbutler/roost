---
import { Image } from 'astro:assets';
import logo from '../assets/roost-logo.png';

const repo = 'https://github.com/tylerbutler/roost';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <Image src={logo} alt="" width={40} height={40} class="footer-mark" />
      <div>
        <p class="footer-word">roost</p>
        <p class="footer-tag">Phoenix channel wire protocol helpers for Gleam.</p>
      </div>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <a href={repo} target="_blank" rel="noopener">GitHub</a>
      <a href={`${repo}#readme`} target="_blank" rel="noopener">Docs</a>
      <a href={`${repo}/blob/main/LICENSE`} target="_blank" rel="noopener">MIT License</a>
    </nav>
  </div>

  <div class="container footer-base">
    <p>© {year} · roost · pre-0.1, no Hex release yet</p>
    <p class="footer-note">A protocol codec — runtime-neutral, on purpose.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-soft);
    background: var(--bg-deep);
    padding-block: clamp(2.5rem, 5vw, 3.5rem) 2rem;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .footer-mark {
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: drop-shadow(0 2px 10px var(--brand-glow));
  }

  .footer-word {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--ink);
    line-height: 1.2;
  }

  .footer-tag {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: 0.95rem;
    color: var(--ink-2);
  }

  .footer-links a {
    transition: color 0.18s var(--ease-out-quint);
  }
  .footer-links a:hover {
    color: var(--brand-bright);
  }

  .footer-base {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--faint);
  }
</style>
